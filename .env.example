# =============================================================================
# Aureva-Insights — environment template
# =============================================================================
# LOCAL:  cp .env.example .env  (repo root; gitignored)
# RENDER: set only [Server] variables (Root Directory: server)
# VERCEL: set only [Client] variables (Root Directory: client)
# =============================================================================

# --- Server (Render + local backend) ---
# PORT: Render sets this automatically — omit on Render; use 5000 locally
PORT=5000
NODE_ENV=development
MONGO_URI=your_mongodb_connection_string
CLERK_SECRET_KEY=your_clerk_secret_key
# Optional on server; required on Render if your Clerk setup expects it
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
# Local dev default; on Render use your Vercel URL (comma-separated for previews)
FRONTEND_URL=http://localhost:5173

# --- Client (Vercel + local frontend; VITE_ prefix required) ---
# Local: leave empty to use Vite proxy (/api -> http://localhost:5000)
# Vercel: your Render service URL, no trailing slash
VITE_API_URL=
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# --- Deployed values (reference — set in host dashboards, not committed) ---
# Render FRONTEND_URL=https://your-app.vercel.app
# Vercel VITE_API_URL=https://your-service.onrender.com
